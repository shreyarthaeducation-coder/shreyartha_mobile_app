{
  "expo": {
    "name": "The 3C Edge",
    "slug": "shreyartha-mobile-app",
    "version": "1.2.0",
    "scheme": "shreyartha",
    "orientation": "portrait",
    "icon": "./assets/images/AppLogo.png",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android"],
    "splash": {
      "image": "./assets/images/AppLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.the3cedgeai.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.the3cedgeai.app",
      "versionCode": 7,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "@react-native-community/datetimepicker"],
    "extra": {
      "router": {},
      "apiBaseUrl": "https://shreyartha.com",
      "eas": {
        "projectId": "3895f096-be3e-4a55-b755-ebc8c28181a2"
      }
    }
  }
}
